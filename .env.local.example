# Configuração de E-mail (SMTP)
# Para Gmail, você precisa criar uma "Senha de App":
# 1. Acesse: https://myaccount.google.com/security
# 2. Ative a verificação em duas etapas
# 3. Vá em "Senhas de app" e gere uma senha para "Aplicativo de e-mail"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-aqui

# URL da aplicação (usado nos links dos e-mails)
NEXT_PUBLIC_URL=http://localhost:3000

# Autenticacao interna (JWT simples)
# Gere um segredo forte (min. 32 caracteres).
AUTH_JWT_SECRET=troque-por-um-segredo-forte-aqui
# Tempo de vida do token em segundos (padrao: 8 horas)
AUTH_JWT_TTL_SECONDS=28800
# Opcional: instituicao padrao para login mock
DEFAULT_INSTITUICAO_ID=

# ─────────────────────────────────────────────────────────────────────────────
# EFI Bank — API Cobranças (Boleto / Carnê)
# Obtenha em: https://app.sejaefi.com.br → API → Criar aplicação → Emissões
# ─────────────────────────────────────────────────────────────────────────────
EFI_CLIENT_ID=seu-client-id-efi
EFI_CLIENT_SECRET=seu-client-secret-efi
# true = homologação (testes), false (ou omitir) = produção
EFI_SANDBOX=true
